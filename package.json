{
  "name": "traingame",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @traingame/server\" \"npm run dev --workspace @traingame/client\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "seed": "npm run seed --workspace @traingame/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.4.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.16.0"
  }
}
